class Solution:
    def longestConsecutive(self, nums: List[int]) -> int:
        maxlength=0
        curr=0
        ns=set(nums)
        for num in ns:
            if num-1 not in ns:
                curr=num
                le=1
                while curr+1 in ns:
                    curr+=1
                    le+=1
                maxlength=max(le,maxlength)
        return maxlength
