class Solution:
    def longestConsecutive(self, nums: List[int]) -> int:
        if not nums:
            return 0
        nums.sort()
        length=1
        curr=1
        for i in range(1,len(nums)):
            if nums[i-1]==nums[i]:
                continue
            elif nums[i-1]+1==nums[i]:
                curr+=1
                length=max(length,curr)
            else:
                curr=1
        return length
